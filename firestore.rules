rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow creating user documents during login
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow reading user data for search purposes
      allow read: if request.auth != null && 
        request.query.limit <= 50; // Limit search results
    }
    
    // Calls collection
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }
    
    // ICE candidates subcollection
    match /calls/{callId}/iceCandidates/{candidateId} {
      allow read, write: if request.auth != null;
    }
  }
}
